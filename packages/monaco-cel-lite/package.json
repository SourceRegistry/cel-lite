{
  "name": "@sourceregistry/monaco-cel-lite",
  "version": "1.1.1",
  "description": "Monaco Editor language + IntelliSense for CEL-lite.",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "monaco-editor": "^0.53.0"
  },
  "scripts": {
    "build": "tsc && vite build",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0"
  },
  "keywords": [
    "monaco",
    "vscode-extension",
    "cel-lite",
    "cel"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "tagFormat": "@sourceregistry/monaco-cel-lite-v${version}",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "node ../../scripts/semantic-release-version.mjs . ${nextRelease.version}",
          "publishCmd": "npm publish --access public --provenance"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "monaco-cel-lite(release): 🚀 v${nextRelease.version}\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
